#!/usr/bin/env bash
set -euo pipefail
# Preferred Hive CLI entrypoint: auto-connects to local HS2 via HTTP.
APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [[ "${1:-}" == "--version" || "${1:-}" == "-version" ]]; then
  exec /opt/hive/bin/hive --version
fi
exec bash "${APP_ROOT}/scripts/hive/cli.sh" "$@"
