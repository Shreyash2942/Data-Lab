#!/usr/bin/env bash
set -euo pipefail

RUNTIME_ROOT="${RUNTIME_ROOT:-${HOME}/runtime}"
SPARK_CONF_DIR_DEFAULT="${RUNTIME_ROOT}/spark/conf"
SPARK_BIN="${SPARK_HOME:-/opt/spark}/bin/spark-submit"
HADOOP_HOME="${HADOOP_HOME:-/opt/hadoop}"
HADOOP_COMMON_LIB_NATIVE_DIR="${HADOOP_COMMON_LIB_NATIVE_DIR:-${HADOOP_HOME}/lib/native}"
LOG_LEVEL="${DATALAB_SPARK_LOG_LEVEL:-ERROR}"
LOG_LEVEL="$(printf '%s' "${LOG_LEVEL}" | tr '[:lower:]' '[:upper:]')"
HUDI_LOG_LEVEL="${DATALAB_HUDI_LOG_LEVEL:-ERROR}"
HUDI_LOG_LEVEL="$(printf '%s' "${HUDI_LOG_LEVEL}" | tr '[:lower:]' '[:upper:]')"
JETTY_LOG_LEVEL="${DATALAB_JETTY_LOG_LEVEL:-ERROR}"
JETTY_LOG_LEVEL="$(printf '%s' "${JETTY_LOG_LEVEL}" | tr '[:lower:]' '[:upper:]')"
JAVALIN_LOG_LEVEL="${DATALAB_JAVALIN_LOG_LEVEL:-ERROR}"
JAVALIN_LOG_LEVEL="$(printf '%s' "${JAVALIN_LOG_LEVEL}" | tr '[:lower:]' '[:upper:]')"
VERBOSE_MODE="${DATALAB_SPARK_VERBOSE:-0}"
MAX_TO_STRING_FIELDS="${DATALAB_SPARK_MAX_TO_STRING_FIELDS:-1000}"
FILTER_JOL_WARNINGS="${DATALAB_FILTER_JOL_WARNINGS:-1}"

LOG4J_FILE="${SPARK_CONF_DIR_DEFAULT}/log4j2.properties"
if ! mkdir -p "${SPARK_CONF_DIR_DEFAULT}" 2>/dev/null; then
  SPARK_CONF_DIR_DEFAULT="${HOME}/.datalab/spark/conf"
  LOG4J_FILE="${SPARK_CONF_DIR_DEFAULT}/log4j2.properties"
  mkdir -p "${SPARK_CONF_DIR_DEFAULT}"
fi

ensure_log4j() {
  if [ -f "${LOG4J_FILE}" ]; then
    return
  fi

  local template="${SPARK_CONF_DIR_DEFAULT}/log4j2.properties.template"
  if [ ! -f "${template}" ] && [ -f "${SPARK_HOME:-/opt/spark}/conf/log4j2.properties.template" ]; then
    template="${SPARK_HOME:-/opt/spark}/conf/log4j2.properties.template"
  fi

  if [ -f "${template}" ]; then
    tr -d '\r' < "${template}" > "${LOG4J_FILE}"
  else
    printf 'rootLogger.level = %s\n' "${LOG_LEVEL}" > "${LOG4J_FILE}"
  fi
}

set_log_level() {
  local file="$1"
  local file_dir
  file_dir="$(dirname "${file}")"
  if [[ ! -w "${file_dir}" ]] || [[ -f "${file}" && ! -w "${file}" ]]; then
    return 0
  fi

  if grep -q "rootLogger.level" "${file}" 2>/dev/null; then
    sed -E "s/rootLogger\\.level[[:space:]]*=[[:space:]]*[A-Za-z]+/rootLogger.level = ${LOG_LEVEL}/" "${file}" > "${file}.tmp" 2>/dev/null && mv "${file}.tmp" "${file}" 2>/dev/null || true
  else
    printf 'rootLogger.level = %s\n' "${LOG_LEVEL}" >> "${file}" 2>/dev/null || true
  fi

  upsert_logger() {
    local key="$1"
    local name="$2"
    local level="$3"

    if grep -q "logger\\.${key}\\.name" "${file}" 2>/dev/null; then
      sed -E "s|logger\\.${key}\\.name[[:space:]]*=[[:space:]]*.*$|logger.${key}.name = ${name}|" "${file}" > "${file}.tmp" 2>/dev/null && mv "${file}.tmp" "${file}" 2>/dev/null || true
    else
      printf 'logger.%s.name = %s\n' "${key}" "${name}" >> "${file}" 2>/dev/null || true
    fi

    if grep -q "logger\\.${key}\\.level" "${file}" 2>/dev/null; then
      sed -E "s/logger\\.${key}\\.level[[:space:]]*=[[:space:]]*[A-Za-z]+/logger.${key}.level = ${level}/" "${file}" > "${file}.tmp" 2>/dev/null && mv "${file}.tmp" "${file}" 2>/dev/null || true
    else
      printf 'logger.%s.level = %s\n' "${key}" "${level}" >> "${file}" 2>/dev/null || true
    fi
  }

  upsert_logger "spark" "org.apache.spark" "${LOG_LEVEL}"
  upsert_logger "hudi" "org.apache.hudi" "${HUDI_LOG_LEVEL}"
  upsert_logger "hadoop" "org.apache.hadoop" "${LOG_LEVEL}"
  upsert_logger "jetty" "org.eclipse.jetty" "${JETTY_LOG_LEVEL}"
  upsert_logger "javalin" "io.javalin" "${JAVALIN_LOG_LEVEL}"
}

ensure_log4j
set_log_level "${LOG4J_FILE}" || true

export SPARK_CONF_DIR="${SPARK_CONF_DIR:-${SPARK_CONF_DIR_DEFAULT}}"
export HADOOP_HOME HADOOP_COMMON_LIB_NATIVE_DIR
export LD_LIBRARY_PATH="${HADOOP_COMMON_LIB_NATIVE_DIR}:${LD_LIBRARY_PATH:-}"

DEFAULT_SUBMIT_OPTS=(
  "-Dlog4j.configurationFile=${LOG4J_FILE}"
  "-Djava.library.path=${HADOOP_COMMON_LIB_NATIVE_DIR}"
  "-Divy.message.logger.level=1"
)
export SPARK_SUBMIT_OPTS="${DEFAULT_SUBMIT_OPTS[*]} ${SPARK_SUBMIT_OPTS:-}"

DRIVER_EXTRA_JAVA_OPTS="-Dlog4j.configurationFile=${LOG4J_FILE} -Djava.library.path=${HADOOP_COMMON_LIB_NATIVE_DIR}"
EXECUTOR_EXTRA_JAVA_OPTS="-Dlog4j.configurationFile=${LOG4J_FILE} -Djava.library.path=${HADOOP_COMMON_LIB_NATIVE_DIR}"

# Allow self-attach so JOL/agent probing won't emit warning noise in most container runs.
DRIVER_EXTRA_JAVA_OPTS="${DRIVER_EXTRA_JAVA_OPTS} -Djdk.attach.allowAttachSelf=true"
EXECUTOR_EXTRA_JAVA_OPTS="${EXECUTOR_EXTRA_JAVA_OPTS} -Djdk.attach.allowAttachSelf=true"

QUIET_ARGS=()
if [[ "${VERBOSE_MODE}" != "1" ]]; then
  QUIET_ARGS+=(
    "--conf" "spark.ui.showConsoleProgress=false"
    "--conf" "spark.driver.extraJavaOptions=${DRIVER_EXTRA_JAVA_OPTS}"
    "--conf" "spark.executor.extraJavaOptions=${EXECUTOR_EXTRA_JAVA_OPTS}"
    "--conf" "spark.sql.debug.maxToStringFields=${MAX_TO_STRING_FIELDS}"
  )
else
  QUIET_ARGS+=(
    "--conf" "spark.driver.extraJavaOptions=${DRIVER_EXTRA_JAVA_OPTS}"
    "--conf" "spark.executor.extraJavaOptions=${EXECUTOR_EXTRA_JAVA_OPTS}"
    "--conf" "spark.sql.debug.maxToStringFields=${MAX_TO_STRING_FIELDS}"
  )
fi

# If shared runtime paths are root-owned, fall back to user-writable paths so
# `spark-submit` still works for the `datalab` user.
EVENT_DIR="${RUNTIME_ROOT}/spark/events"
WAREHOUSE_DIR="${RUNTIME_ROOT}/spark/warehouse"
USER_EVENT_DIR="${HOME}/.datalab/spark/events"
USER_WAREHOUSE_DIR="${HOME}/.datalab/spark/warehouse"
EXTRA_CONF_ARGS=()

can_write_dir() {
  local dir="$1"
  local probe="${dir}/.write_test_$$"
  mkdir -p "${dir}" 2>/dev/null || return 1
  : > "${probe}" 2>/dev/null || return 1
  rm -f "${probe}" 2>/dev/null || true
  return 0
}

if ! can_write_dir "${EVENT_DIR}"; then
  mkdir -p "${USER_EVENT_DIR}"
  EXTRA_CONF_ARGS+=(
    "--conf" "spark.eventLog.enabled=true"
    "--conf" "spark.eventLog.dir=file://${USER_EVENT_DIR}"
    "--conf" "spark.history.fs.logDirectory=file://${USER_EVENT_DIR}"
  )
fi

if ! can_write_dir "${WAREHOUSE_DIR}"; then
  mkdir -p "${USER_WAREHOUSE_DIR}"
  EXTRA_CONF_ARGS+=(
    "--conf" "spark.sql.warehouse.dir=${USER_WAREHOUSE_DIR}"
  )
fi

if [[ "${FILTER_JOL_WARNINGS}" == "1" ]]; then
  exec "${SPARK_BIN}" "${QUIET_ARGS[@]}" "${EXTRA_CONF_ARGS[@]}" "$@" \
    2> >(grep -E -v '^# WARNING: Unable to (get Instrumentation|attach Serviceability Agent)' >&2)
else
  exec "${SPARK_BIN}" "${QUIET_ARGS[@]}" "${EXTRA_CONF_ARGS[@]}" "$@"
fi
