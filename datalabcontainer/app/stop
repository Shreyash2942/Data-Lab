#!/usr/bin/env bash
set -e

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_REPO_ROOT="$(cd "${APP_DIR}/.." && pwd)"
SERVICE_NAME="${SERVICE_NAME:-data-lab}"
CONTAINER_NAME="${CONTAINER_NAME:-datalab}"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
source "${APP_DIR}/tech/host_exec.sh"

datalab::ensure_inside_or_exec "${APP_REPO_ROOT}" "${SERVICE_NAME}" "${CONTAINER_NAME}" "/home/datalab/app/${SCRIPT_NAME}" "$@"

source "${APP_DIR}/tech/common.sh"
source "${APP_DIR}/tech/hadoop/manage.sh"
source "${APP_DIR}/tech/hive/manage.sh"
source "${APP_DIR}/tech/airflow/manage.sh"
source "${APP_DIR}/tech/kafka/manage.sh"
source "${APP_DIR}/tech/postgres/manage.sh"
source "${APP_DIR}/tech/mongodb/manage.sh"
source "${APP_DIR}/tech/redis/manage.sh"
source "${APP_DIR}/tech/dbui/manage.sh"
source "${APP_DIR}/tech/pgadmin/manage.sh"
source "${APP_DIR}/tech/spark/manage.sh"
source "${APP_DIR}/tech/minio/manage.sh"
source "${APP_DIR}/tech/trino/manage.sh"
source "${APP_DIR}/tech/superset/manage.sh"
source "${APP_DIR}/tech/service_groups.sh"
source "${APP_DIR}/tech/cli_flags.sh"

handle_cli_flag() {
  case "$1" in
    --stop-etl-stack)
      groups::stop_etl
      echo "[+] ETL stack stopped."
      exit 0
      ;;
    --stop-database-stack|--stop-databases)
      groups::stop_databases
      echo "[+] Database stack stopped (PostgreSQL/MongoDB/Redis + Mongo Express/Redis Commander/pgAdmin)."
      exit 0
      ;;
    --stop-lakehouse-stack|--stop-lakehouse)
      groups::stop_lakehouse
      echo "[+] Lakehouse services stopped."
      exit 0
      ;;
    --stop-full-platform)
      groups::stop_full_platform
      echo "[+] Full platform stopped."
      exit 0
      ;;
    --stop-spark) spark::stop; exit 0 ;;
    --stop-hadoop) hadoop::stop; exit 0 ;;
    --stop-hive) hive::stop; exit 0 ;;
    --stop-kafka) kafka::stop; exit 0 ;;
    --stop-airflow) airflow::stop; exit 0 ;;
    --stop-postgres) postgres::stop; exit 0 ;;
    --stop-mongodb) dbui::stop_mongo_express; mongodb::stop; exit 0 ;;
    --stop-redis) dbui::stop_redis_commander; redis::stop; exit 0 ;;
    --stop-mongo-express) dbui::stop_mongo_express; exit 0 ;;
    --stop-redis-commander) dbui::stop_redis_commander; exit 0 ;;
    --stop-db-uis) dbui::stop; pgadmin::stop; exit 0 ;;
    --stop-pgadmin) pgadmin::stop; exit 0 ;;
    --stop-minio) minio::stop; exit 0 ;;
    --stop-trino) trino::stop; exit 0 ;;
    --stop-superset) superset::stop; exit 0 ;;
    --stop-core)
      groups::stop_etl
      echo "[+] Spark/Hadoop/Hive/Kafka services stopped."
      exit 0
      ;;
  esac
}

CLI_FLAG="$(cli::normalize_flag "${1:-}")"
handle_cli_flag "${CLI_FLAG}" || true

echo "=== Data Lab :: STOP MENU ==="
echo "1) Stop Spark services"
echo "2) Stop Hadoop services"
echo "3) Stop Hive services"
echo "4) Stop Kafka services"
echo "5) Stop Airflow webserver & scheduler"
echo "6) Stop ALL core services (Spark/Hadoop/Hive/Kafka)"
echo "7) Stop PostgreSQL service"
echo "8) Stop MongoDB service"
echo "9) Stop Redis service"
echo "10) Stop all databases (PostgreSQL/MongoDB/Redis)"
echo "11) Stop DB UIs (Mongo Express/Redis Commander/pgAdmin)"
echo "12) Stop MinIO service"
echo "13) Stop Trino service"
echo "14) Stop Superset UI"
echo "15) Stop lakehouse services (MinIO/Trino/Superset)"
echo "16) Stop Docker container"
echo "0) Exit"
read -p "Select option: " opt

case "$opt" in
  1)
    spark::stop
    echo "[+] Spark services stopped."
    ;;
  2)
    hadoop::stop
    echo "[+] Hadoop services stopped."
    ;;
  3)
    hive::stop
    echo "[+] Hive services stopped."
    ;;
  4)
    kafka::stop
    echo "[+] Kafka services stopped."
    ;;
  5)
    airflow::stop
    echo "[+] Airflow services stopped."
    ;;
  6)
    groups::stop_etl
    echo "[+] Spark/Hadoop/Hive/Kafka services stopped."
    ;;
  7)
    postgres::stop
    echo "[+] PostgreSQL service stopped."
    ;;
  8)
    dbui::stop_mongo_express
    mongodb::stop
    echo "[+] MongoDB service stopped."
    ;;
  9)
    dbui::stop_redis_commander
    redis::stop
    echo "[+] Redis service stopped."
    ;;
  10)
    groups::stop_databases
    echo "[+] PostgreSQL, MongoDB, and Redis services stopped."
    ;;
  11)
    dbui::stop
    pgadmin::stop
    echo "[+] Database UIs stopped."
    ;;
  12)
    minio::stop
    echo "[+] MinIO service stopped."
    ;;
  13)
    trino::stop
    echo "[+] Trino service stopped."
    ;;
  14)
    superset::stop
    echo "[+] Superset UI stopped."
    ;;
  15)
    groups::stop_lakehouse
    echo "[+] Lakehouse services stopped."
    ;;
  16)
    (
      cd "${APP_REPO_ROOT}"
      docker compose stop "${SERVICE_NAME}"
    )
    ;;
  0)
    echo "Bye."
    ;;
  *)
    echo "Invalid option."
    exit 1
    ;;
esac
