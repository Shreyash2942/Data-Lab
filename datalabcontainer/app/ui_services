print_ui_json_host() {
  local container="$1"
  local pg_port mongo_port redis_port
  pg_port="$(mapped_host_port "${container}" 5432)"
  mongo_port="$(mapped_host_port "${container}" 27017)"
  redis_port="$(mapped_host_port "${container}" 6379)"
  cat <<EOF
{
  "container": "$(json_escape "${container}")",
  "hdfs_fs_uri": "$(json_escape "$(read_fs_defaultfs)")",
  "hive_warehouse_dir": "$(json_escape "$(read_hive_warehouse_dir)")",
  "hive_metastore_endpoint": "$(json_escape "$(mapped_endpoint "${container}" 9083 "thrift")")",
  "spark_rpc": "$(json_escape "$(mapped_endpoint "${container}" 7077 "spark")")",
  "kafka_broker": "$(json_escape "$(mapped_endpoint "${container}" 9092 "kafka")")",
  "postgresql": {
    "server_name": "$(json_escape "${container}")",
    "inside": "postgresql://localhost:5432",
    "outside": "postgresql://$(json_escape "${UI_HOST}"):${pg_port}"
  },
  "mongodb": {
    "server_name": "$(json_escape "${container}")",
    "inside": "mongodb://localhost:27017",
    "outside": "mongodb://$(json_escape "${UI_HOST}"):${mongo_port}"
  },
  "redis": {
    "server_name": "$(json_escape "${container}")",
    "inside": "redis://localhost:6379",
    "outside": "redis://$(json_escape "${UI_HOST}"):${redis_port}"
  }
}
EOF
}

