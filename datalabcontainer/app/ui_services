#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_REPO_ROOT="$(cd "${APP_DIR}/.." && pwd)"
SERVICE_NAME="${SERVICE_NAME:-data-lab}"
CONTAINER_NAME="${CONTAINER_NAME:-datalab}"
source "${APP_DIR}/scripts/host_exec.sh"

UI_HOST="${UI_HOST:-localhost}"
: "${UI_ACTION:=${1:-}}"
: "${DATALAB_UI_HOST:=}"
: "${DATALAB_HOST_PORT_MAP:=}"
UI_MAP_FILE="${UI_MAP_FILE:-/home/datalab/runtime/ui-port-map.env}"

if [[ -f "${UI_MAP_FILE}" ]]; then
  # Read persisted mapping for copied containers so values survive `su - datalab`.
  while IFS='=' read -r key value; do
    key="${key//$'\r'/}"
    value="${value//$'\r'/}"
    case "${key}" in
      DATALAB_UI_HOST) [[ -n "${value}" ]] && DATALAB_UI_HOST="${value}" ;;
      DATALAB_HOST_PORT_MAP) [[ -n "${value}" ]] && DATALAB_HOST_PORT_MAP="${value}" ;;
    esac
  done < "${UI_MAP_FILE}"
fi

if [[ -n "${DATALAB_UI_HOST}" ]]; then
  UI_HOST="${DATALAB_UI_HOST}"
fi

print_header() {
  echo "=== Data Lab UI Services ==="
}

UI_CACHE_FS_DEFAULTFS=""
UI_CACHE_HIVE_SITE_PATH=""
UI_CACHE_HIVE_PROPS=""
UI_CACHE_HIVE_PROPS_LOADED=0

json_escape() {
  local s="${1:-}"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/}"
  printf '%s' "${s}"
}

print_row() {
  local name="$1"
  local url="$2"
  name="${name//$'\r'/}"
  url="${url//$'\r'/}"
  printf '%-20s %s\n' "${name}:" "${url}"
}

print_section() {
  local title="$1"
  echo
  echo "=== ${title} ==="
}

print_kv() {
  local key="$1"
  local value="$2"
  key="${key//$'\r'/}"
  value="${value//$'\r'/}"
  printf '  %-28s %s\n' "${key}:" "${value}"
}

prompt_default() {
  local label="$1"
  local def="$2"
  local val
  local shown_def="${def}"
  if [[ -z "${shown_def}" ]]; then
    shown_def="(blank)"
  fi
  read -r -p "${label} [${shown_def}]: " val || true
  val="${val//$'\r'/}"
  if [[ -z "${val}" ]]; then
    printf '%s' "${def}"
  else
    printf '%s' "${val}"
  fi
}

read_fs_defaultfs() {
  if [[ -n "${UI_CACHE_FS_DEFAULTFS}" ]]; then
    printf '%s' "${UI_CACHE_FS_DEFAULTFS}"
    return 0
  fi

  local core_site_paths=(
    "${HADOOP_CONF_DIR:-/opt/hadoop/etc/hadoop}/core-site.xml"
    "/home/datalab/hadoop/conf/core-site.xml"
    "/opt/hadoop/etc/hadoop/core-site.xml"
  )
  local core_site fs_uri

  for core_site in "${core_site_paths[@]}"; do
    if [[ -f "${core_site}" ]]; then
      fs_uri="$(awk '
        /<name>[[:space:]]*fs.defaultFS[[:space:]]*<\/name>/ { in_prop=1; next }
        in_prop && /<value>/ {
          gsub(/.*<value>[[:space:]]*/, "", $0)
          gsub(/[[:space:]]*<\/value>.*/, "", $0)
          print
          exit
        }
        /<\/property>/ { in_prop=0 }
      ' "${core_site}" 2>/dev/null || true)"
      fs_uri="${fs_uri//$'\r'/}"
      if [[ -n "${fs_uri}" ]]; then
        UI_CACHE_FS_DEFAULTFS="${fs_uri}"
        printf '%s' "${fs_uri}"
        return 0
      fi
    fi
  done

  UI_CACHE_FS_DEFAULTFS="(not found)"
  printf '%s' "${UI_CACHE_FS_DEFAULTFS}"
}

read_hive_site_path() {
  if [[ -n "${UI_CACHE_HIVE_SITE_PATH}" ]]; then
    printf '%s' "${UI_CACHE_HIVE_SITE_PATH}"
    return 0
  fi

  local candidates=(
    "${HIVE_CONF_DIR:-/opt/hive/conf}/hive-site.xml"
    "${APP_REPO_ROOT}/dev/hive/conf/hive-site.xml"
    "/home/datalab/hive/conf/hive-site.xml"
    "/opt/hive/conf/hive-site.xml"
  )
  local candidate

  for candidate in "${candidates[@]}"; do
    if [[ -f "${candidate}" ]]; then
      UI_CACHE_HIVE_SITE_PATH="${candidate}"
      printf '%s' "${candidate}"
      return 0
    fi
  done

  UI_CACHE_HIVE_SITE_PATH="(not found)"
  printf '%s' "${UI_CACHE_HIVE_SITE_PATH}"
}

load_hive_site_properties_cache() {
  if [[ "${UI_CACHE_HIVE_PROPS_LOADED}" -eq 1 ]]; then
    return 0
  fi

  local hive_site
  hive_site="$(read_hive_site_path)"
  if [[ "${hive_site}" == "(not found)" ]]; then
    UI_CACHE_HIVE_PROPS=""
    UI_CACHE_HIVE_PROPS_LOADED=1
    return 1
  fi

  UI_CACHE_HIVE_PROPS="$(awk '
    /<property>/ { in_prop=1; name=""; value=""; next }
    in_prop && /<name>/ {
      line=$0
      gsub(/.*<name>[[:space:]]*/, "", line)
      gsub(/[[:space:]]*<\/name>.*/, "", line)
      name=line
      next
    }
    in_prop && /<value>/ {
      line=$0
      gsub(/.*<value>[[:space:]]*/, "", line)
      gsub(/[[:space:]]*<\/value>.*/, "", line)
      value=line
      next
    }
    /<\/property>/ {
      if (in_prop && name != "") {
        print name "\t" value
      }
      in_prop=0
    }
  ' "${hive_site}" 2>/dev/null || true)"
  UI_CACHE_HIVE_PROPS_LOADED=1
}

read_hive_site_property() {
  local property_name="$1"
  local property_value

  if ! load_hive_site_properties_cache; then
    return 1
  fi

  property_value="$(printf '%s\n' "${UI_CACHE_HIVE_PROPS}" | awk -F '\t' -v p="${property_name}" '$1 == p { print $2; exit }')"
  property_value="${property_value//$'\r'/}"
  if [[ -n "${property_value}" ]]; then
    printf '%s' "${property_value}"
    return 0
  fi
  return 1
}

