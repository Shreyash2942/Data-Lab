port_open_local() {
  local host="$1" port="$2"
  UI_WAIT_HOST="${host}" UI_WAIT_PORT="${port}" python3 - <<'PY'
import os, socket, sys
host = os.environ["UI_WAIT_HOST"]
port = int(os.environ["UI_WAIT_PORT"])
s = socket.socket()
s.settimeout(1)
try:
    s.connect((host, port))
except OSError:
    sys.exit(1)
else:
    s.close()
    sys.exit(0)
PY
}

ui_login_helper() {
  local selection service_name container_port start_flag service_url service_is_endpoint endpoint_scheme
  local airflow_user="${CONTAINER_NAME:-datalab}"

  while true; do
    echo
    echo "=== Data Lab UI Login Helper ==="
    echo "1) Airflow"
    echo "2) Spark (Master/History/App + Connect)"
    echo "3) HDFS (NameNode + Connect)"
    echo "4) Hive (HS2 + Metastore + Connect)"
    echo "5) Kafka (UI + Connect)"
    echo "6) PostgreSQL (DB + pgAdmin)"
    echo "7) MongoDB (DB + Mongo Express)"
    echo "8) Redis (DB + Redis Commander)"
    echo "0) Exit"
    read -r -p "Select option [0-8]: " selection
    selection="${selection//$'\r'/}"

    service_is_endpoint=0
    endpoint_scheme="http"
    case "${selection}" in
      1) service_name="Airflow"; container_port=8080; start_flag="--start-airflow" ;;
      2) service_name="Spark Master"; container_port=9090; start_flag="--start-core" ;;
      3) service_name="HDFS NameNode"; container_port=9870; start_flag="--start-core" ;;
      4) service_name="HiveServer2 HTTP"; container_port=10001; start_flag="--start-core" ;;
      5) service_name="Kafka UI"; container_port=9002; start_flag="--start-core" ;;
      6)
        service_name="PostgreSQL (DB)"
        container_port=5432
        start_flag="--start-postgres"
        service_is_endpoint=1
        endpoint_scheme="postgresql"
        ;;
      7)
        service_name="MongoDB (DB)"
        container_port=27017
        start_flag="--start-mongodb"
        service_is_endpoint=1
        endpoint_scheme="mongodb"
        ;;
      8)
        service_name="Redis (DB)"
        container_port=6379
        start_flag="--start-redis"
        service_is_endpoint=1
        endpoint_scheme="redis"
        ;;
      0) echo "Bye."; return 0 ;;
      *) echo "Invalid selection."; echo; continue ;;
    esac

    if [[ "${service_is_endpoint}" -eq 1 ]]; then
      service_url="$(container_effective_endpoint "${container_port}" "${endpoint_scheme}")"
    else
      service_url="$(container_effective_url "${container_port}" "/")"
    fi
    if ! port_open_local localhost "${container_port}"; then
      echo "[!] ${service_name} is not running on port ${container_port}."
      echo "Start it with: datalab_app ${start_flag}"
      read -r -p "Start now? [y/N]: " start_now
      if [[ "${start_now}" =~ ^[Yy]$ ]]; then
        bash /home/datalab/app/start "${start_flag}" >/dev/null || true
      fi
    fi

    if ! port_open_local localhost "${container_port}"; then
      echo "[!] ${service_name} is still not reachable. Check logs and try again."
      echo
      continue
    fi

    echo
    echo "Service: ${service_name}"
    echo "URL: ${service_url}"
    case "${selection}" in
      1)
        echo "Login: username=${airflow_user} password=admin"
        ;;
      2)
        show_spark_connect_info
        ;;
      3)
        echo "HDFS: no UI login required."
        show_hdfs_connect_info
        ;;
      4)
        show_hive_connect_info
        echo "Hive metastore thrift endpoint details:"
        echo "  Endpoint: $(container_effective_endpoint 9083 "thrift")"
        echo "  Auth: none (default)"
        echo "  hive-site.xml: $(read_hive_site_path)"
        ;;
      5)
        echo "Kafka UI: no login required (default)."
        show_kafka_connect_info
        ;;
      6)
        local pg_hostport pg_host pg_port
        pg_hostport="$(effective_host_port 5432)"
        pg_host="${pg_hostport%:*}"
        pg_port="${pg_hostport##*:}"
        echo "pgAdmin: $(container_effective_url 8181 "/")"
        echo "pgAdmin login: email=admin@admin.com password=admin"
        echo "pgAdmin server name: ${CONTAINER_NAME:-datalab}"
        echo "PostgreSQL in pgAdmin: host=${pg_host} port=${pg_port} username=${POSTGRES_USER:-admin} password=${POSTGRES_PASSWORD:-admin} db=${POSTGRES_DB:-datalab}"
        show_postgres_connect_info
        ;;
      7)
        echo "Mongo Express: $(container_effective_url 8083 "/")"
        echo "Mongo Express: no UI login (default)."
        show_mongodb_connect_info
        ;;
      8)
        echo "Redis Commander: $(container_effective_url 8084 "/")"
        echo "Redis Commander: no UI login (default)."
        show_redis_connect_info
        ;;
      *)
        echo "Login: no credentials required for this UI."
        ;;
    esac
    echo
  done
}

resolve_target_container() {
  if datalab::container_running "${CONTAINER_NAME}"; then
    printf '%s' "${CONTAINER_NAME}"
    return 0
  fi
  if datalab::container_running "${SERVICE_NAME}"; then
    printf '%s' "${SERVICE_NAME}"
    return 0
  fi
  return 1
}

extract_host_port() {
  local mapping="$1"
  local candidate
  candidate="$(printf '%s\n' "${mapping}" | awk -F: '{print $NF}' | tr -d '\r' | head -n1)"
  if [[ "${candidate}" =~ ^[0-9]+$ ]]; then
    printf '%s' "${candidate}"
    return 0
  fi
  return 1
}

mapped_url() {
  local container="$1"
  local container_port="$2"
  local service_path="${3:-/}"
  local mapping host_port

  mapping="$(docker port "${container}" "${container_port}/tcp" 2>/dev/null || true)"
  if [[ -z "${mapping}" ]]; then
    printf '%s' "(not published)"
    return 0
  fi

  host_port="$(extract_host_port "${mapping}" || true)"
  if [[ -z "${host_port}" ]]; then
    printf '%s' "(published, unable to parse: ${mapping})"
    return 0
  fi

  printf 'http://%s:%s%s' "${UI_HOST}" "${host_port}" "${service_path}"
}

mapped_host_port() {
  local container="$1"
  local container_port="$2"
  local mapping host_port

  mapping="$(docker port "${container}" "${container_port}/tcp" 2>/dev/null || true)"
  if [[ -z "${mapping}" ]]; then
    printf '%s' "(not published)"
    return 0
  fi

  host_port="$(extract_host_port "${mapping}" || true)"
  if [[ -z "${host_port}" ]]; then
    printf '%s' "(published, unable to parse: ${mapping})"
    return 0
  fi

  printf '%s' "${host_port}"
}

mapped_endpoint() {
  local container="$1"
  local container_port="$2"
  local scheme="$3"
  local host_port

  host_port="$(mapped_host_port "${container}" "${container_port}")"
  if [[ "${host_port}" =~ ^[0-9]+$ ]]; then
    printf '%s://%s:%s' "${scheme}" "${UI_HOST}" "${host_port}"
    return 0
  fi
  printf '%s' "${host_port}"
}

container_local_url() {
  local container_port="$1"
  local service_path="${2:-/}"
  printf 'http://%s:%s%s' "${UI_HOST}" "${container_port}" "${service_path}"
}

mapped_port_from_env() {
  local container_port="$1"
  local entry cport hport
  [[ -n "${DATALAB_HOST_PORT_MAP}" ]] || return 1
  IFS=',' read -ra _entries <<< "${DATALAB_HOST_PORT_MAP}"
  for entry in "${_entries[@]}"; do
    entry="${entry//$'\r'/}"
    cport="${entry%%=*}"
    hport="${entry#*=}"
    if [[ "${cport}" == "${container_port}" ]] && [[ "${hport}" =~ ^[0-9]+$ ]]; then
      printf '%s' "${hport}"
      return 0
    fi
  done
  return 1
}

container_effective_url() {
  local container_port="$1"
  local service_path="${2:-/}"
  local mapped
  mapped="$(mapped_port_from_env "${container_port}" || true)"
  if [[ -n "${mapped}" ]]; then
    printf 'http://%s:%s%s' "${UI_HOST}" "${mapped}" "${service_path}"
    return 0
  fi
  container_local_url "${container_port}" "${service_path}"
}

container_effective_endpoint() {
  local container_port="$1"
  local scheme="$2"
  local mapped
  mapped="$(mapped_port_from_env "${container_port}" || true)"
  if [[ -n "${mapped}" ]]; then
    printf '%s://%s:%s' "${scheme}" "${UI_HOST}" "${mapped}"
    return 0
  fi
  printf '%s://%s:%s' "${scheme}" "${UI_HOST}" "${container_port}"
}

print_db_rows() {
  local server_name="$1"
  local pg_host="$2" pg_port="$3" pg_db="$4" pg_user="$5"
  local mongo_host="$6" mongo_port="$7" mongo_db="$8" mongo_user="$9"
  local redis_host="${10}" redis_port="${11}" redis_user="${12}"

  print_row "PostgreSQL Server" "${server_name}"
  print_row "PostgreSQL Config" "host=${pg_host} port=${pg_port} db=${pg_db} user=${pg_user}"
  print_row "MongoDB Server" "${server_name}"
  print_row "MongoDB Config" "host=${mongo_host} port=${mongo_port} db=${mongo_db} user=${mongo_user} authDb=admin"
  print_row "Redis Server" "${server_name}"
  print_row "Redis Config" "host=${redis_host} port=${redis_port} user=${redis_user}"
}

print_ui_block_host() {
  local container="$1"
  local pg_port mongo_port redis_port
  local pg_db pg_user mongo_db mongo_user redis_user

  pg_port="$(mapped_host_port "${container}" 5432)"
  mongo_port="$(mapped_host_port "${container}" 27017)"
  redis_port="$(mapped_host_port "${container}" 6379)"
  pg_db="$(default_postgres_db)"
  pg_user="$(default_postgres_user)"
  mongo_db="$(default_mongo_db)"
  mongo_user="$(default_mongo_user)"
  redis_user="$(default_redis_user)"

  print_row "HDFS FS URI" "$(read_fs_defaultfs)"
  print_row "Bronze Base Path" "$(default_bronze_path)"
  print_row "Silver Base Path" "$(default_silver_path)"
  print_row "Spark RPC" "$(mapped_endpoint "${container}" 7077 "spark")"
  print_row "Kafka Broker" "$(mapped_endpoint "${container}" 9092 "kafka")"
  print_row "Hive JDBC HTTP" "$(mapped_endpoint "${container}" 10001 "jdbc:hive2")"
  print_row "Hive JDBC Binary" "$(mapped_endpoint "${container}" 10000 "jdbc:hive2")"
  print_row "HiveServer2 Thrift" "$(mapped_endpoint "${container}" 10000 "thrift")"
  print_row "Hive Metastore (client endpoint)" "$(mapped_endpoint "${container}" 9083 "thrift")"
  print_row "Hive Config Path" "$(read_hive_site_path)"
  print_row "Hive Warehouse Dir" "$(read_hive_warehouse_dir)"
  print_row "Airflow" "$(mapped_url "${container}" 8080 "/")"
  print_row "Spark Master" "$(mapped_url "${container}" 9090 "/")"
  print_row "Spark History" "$(mapped_url "${container}" 18080 "/")"
  print_row "Spark App UI" "$(mapped_url "${container}" 4040 "/")"
  print_row "HDFS NameNode" "$(mapped_url "${container}" 9870 "/")"
  print_row "YARN ResourceMgr" "$(mapped_url "${container}" 8088 "/")"
  print_row "HiveServer2 HTTP" "$(mapped_url "${container}" 10001 "/cliservice")"
  print_row "Kafka UI" "$(mapped_url "${container}" 9002 "/")"
  print_row "Mongo Express UI" "$(mapped_url "${container}" 8083 "/")"
  print_row "Redis Commander UI" "$(mapped_url "${container}" 8084 "/")"
  print_row "pgAdmin UI" "$(mapped_url "${container}" 8181 "/")"
  print_db_rows "${container}" "${UI_HOST}" "${pg_port}" "${pg_db}" "${pg_user}" "${UI_HOST}" "${mongo_port}" "${mongo_db}" "${mongo_user}" "${UI_HOST}" "${redis_port}" "${redis_user}"
  print_row "PostgreSQL (DB)" "$(mapped_endpoint "${container}" 5432 "postgresql")"
  print_row "MongoDB (DB)" "$(mapped_endpoint "${container}" 27017 "mongodb")"
  print_row "Redis (DB)" "$(mapped_endpoint "${container}" 6379 "redis")"
