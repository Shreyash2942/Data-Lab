if datalab::inside_container; then
  if [[ "${UI_ACTION}" == "--json" ]]; then
    print_ui_json_container
    exit 0
  fi
  if [[ "${UI_ACTION}" == "--list" || "${UI_ACTION}" == "--all" || "${UI_ACTION}" == "--urls" ]]; then
    print_header
    print_ui_block_container
    echo
    echo "Note: Hive Metastore/PostgreSQL/MongoDB/Redis entries are service endpoints, not HTTP web UIs."
    echo "Schema Registry, Kafka Connect, and Marquez API entries are HTTP APIs."
    echo "Great Expectations entry is the generated Data Docs site."
    echo "Hive metastore value shown above is the client endpoint (auto-mapped for copied containers)."
    echo "Hive defaults: auth=NONE user=datalab password=(blank) db=default."
    echo "Hive ports: metastore=9083, hs2-thrift=10000."
    echo
    if [[ -n "${DATALAB_HOST_PORT_MAP}" ]]; then
      echo "Showing host-mapped ports from container env."
    else
      echo "Tip: Run this from host for mapped host ports."
    fi
    exit 0
  fi
  ui_login_helper
  exit 0
fi

if [[ "${UI_ACTION}" != "--list" && "${UI_ACTION}" != "--all" && "${UI_ACTION}" != "--urls" && "${UI_ACTION}" != "--json" ]]; then
  datalab::ensure_inside_or_exec "${APP_REPO_ROOT}" "${SERVICE_NAME}" "${CONTAINER_NAME}" "/home/datalab/app/ui_services" "--login-helper"
  exit 0
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "Docker CLI not found. Install Docker or run inside container." >&2
  exit 1
fi

target_container="$(resolve_target_container || true)"
if [[ -z "${target_container}" ]]; then
  cat >&2 <<EOF
No running Data Lab container found.
Tried container names '${CONTAINER_NAME}' and '${SERVICE_NAME}'.
EOF
  exit 1
fi

if [[ "${UI_ACTION}" == "--json" ]]; then
  print_ui_json_host "${target_container}"
  exit 0
fi
print_header
echo "Container: ${target_container}"
print_ui_block_host "${target_container}"
echo
echo "Note: Hive Metastore/PostgreSQL/MongoDB/Redis entries are service endpoints, not HTTP web UIs."
echo "Schema Registry, Kafka Connect, and Marquez API entries are HTTP APIs."
echo "Great Expectations entry is the generated Data Docs site."
echo "Hive metastore value shown above is the client endpoint (auto-mapped for copied containers)."
echo "Hive defaults: auth=NONE user=datalab password=(blank) db=default."
echo "Hive ports: metastore=9083, hs2-thrift=10000."
