run_stack_validation_dag() {
  local dag_id="data_lab_stack_validation"
  local exec_date
  airflow::start
  exec_date="$(date +%F)"
  echo "[*] Running Airflow DAG '${dag_id}' for date ${exec_date}..."
  if airflow dags test "${dag_id}" "${exec_date}"; then
    if ! VALIDATION_DAG_ID="${dag_id}" python3 - <<'PY'
from airflow.models import DagRun, TaskInstance
from airflow.utils.session import create_session

dag_id = __import__("os").environ["VALIDATION_DAG_ID"]
with create_session() as session:
    dag_run = (
        session.query(DagRun)
        .filter(DagRun.dag_id == dag_id)
        .order_by(DagRun.execution_date.desc())
        .first()
    )
    if dag_run is None:
        raise SystemExit(f"No DagRun found for {dag_id}")

    task_instances = (
        session.query(TaskInstance)
        .filter(TaskInstance.dag_id == dag_id, TaskInstance.run_id == dag_run.run_id)
        .all()
    )
    failures = [
        ti for ti in task_instances
        if ti.state != "success" and ti.task_id != "cleanup_validation_artifacts"
    ]
    if failures:
        details = ", ".join(f"{ti.task_id}={ti.state}" for ti in failures)
        raise SystemExit(f"Validation DAG had failed or skipped tasks: {details}")
PY
    then
      echo "[!] Airflow DAG '${dag_id}' finished with failed or skipped tasks." >&2
      return 1
    fi
    echo "[+] Airflow DAG '${dag_id}' completed successfully."
  else
    echo "[!] Airflow DAG '${dag_id}' failed. Check Airflow task logs for details." >&2
    return 1
  fi
}

port_is_open() {
  local host="$1" port="$2"
  STATUS_WAIT_HOST="${host}" STATUS_WAIT_PORT="${port}" python3 - <<'PY'
import os, socket, sys
host = os.environ["STATUS_WAIT_HOST"]
port = int(os.environ["STATUS_WAIT_PORT"])
s = socket.socket()
s.settimeout(1)
try:
    s.connect((host, port))
except OSError:
    sys.exit(1)
else:
    s.close()
    sys.exit(0)
PY
}

http_probe_ok() {
  local port="$1" path="$2"
  STATUS_HTTP_PORT="${port}" STATUS_HTTP_PATH="${path}" python3 - <<'PY'
import os, sys, urllib.error, urllib.request
port = int(os.environ["STATUS_HTTP_PORT"])
path = os.environ["STATUS_HTTP_PATH"]
request = urllib.request.Request(
    f"http://127.0.0.1:{port}{path}",
    headers={"User-Agent": "datalab-status-report"},
)
try:
    with urllib.request.urlopen(request, timeout=2) as response:
        sys.exit(0 if response.status < 500 else 1)
except urllib.error.HTTPError as exc:
    sys.exit(0 if exc.code < 500 else 1)
except Exception:
    sys.exit(1)
PY
}

status_probe_endpoint() {
  local port="$1" probe="$2" path="${3:-/}"
  local host mapped_port

  host="${DATALAB_UI_HOST:-localhost}"
  mapped_port="$(common::mapped_host_port "${port}")"

  if [[ "${probe}" == "http" ]]; then
    common::ui_url "${port}" "${path}"
    return 0
  fi

  case "${port}" in
    5432)
      printf 'postgresql://%s:%s' "${host}" "${mapped_port}"
      ;;
    27017)
      printf 'mongodb://%s:%s' "${host}" "${mapped_port}"
      ;;
    6379)
      printf 'redis://%s:%s' "${host}" "${mapped_port}"
      ;;
    10000|9083)
      printf 'thrift://%s:%s' "${host}" "${mapped_port}"
      ;;
    *)
      printf '%s:%s' "${host}" "${mapped_port}"
      ;;
  esac
}

show_running_services() {
  local services=(
    "Airflow:8080"
    "Spark Master:9090"
    "Hadoop NameNode:9870"
    "HiveServer2:10000"
    "Kafka UI:9002"
    "Schema Registry:8085"
    "Kafka Connect:8086"
    "PostgreSQL:5432"
    "MongoDB:27017"
    "Redis:6379"
    "Mongo Express:8083"
    "Redis Commander:8084"
    "JupyterLab:8888"
    "GX Data Docs:8891"
    "Marquez API:5000"
    "Marquez UI:3000"
    "Prometheus:9095"
    "Grafana:3001"
    "MinIO:${MINIO_API_PORT}"
    "Trino:8091"
    "Superset:8090"
  )
  local entry name port status

  echo "=== Running Services ==="
  for entry in "${services[@]}"; do
    name="${entry%%:*}"
    port="${entry##*:}"
    if [[ "${name}" == "MinIO" ]]; then
      if minio::is_running; then
        status="running"
      else
        status="stopped"
      fi
    elif port_is_open localhost "${port}"; then
      status="running"
    else
      status="stopped"
    fi
    printf '  %-18s %s\n' "${name}:" "${status}"
  done
}

show_service_health_report() {
  local -a services=(
    "Airflow|8080|http|/"
    "Spark Master|9090|http|/metrics/master/prometheus"
    "HDFS NameNode|9870|http|/"
    "HiveServer2|10000|tcp|"
    "Kafka Broker|9092|tcp|"
    "Kafka UI|9002|http|/"
    "Schema Registry|8085|http|/apis/registry/v3/system/info"
    "Kafka Connect|8086|http|/connectors"
    "PostgreSQL|5432|tcp|"
    "MongoDB|27017|tcp|"
    "Redis|6379|tcp|"
    "Mongo Express|8083|http|/"
    "Redis Commander|8084|http|/"
    "pgAdmin|8181|http|/"
    "JupyterLab|8888|http|/login"
    "GX Data Docs|8891|http|/"
    "Marquez API|5000|http|/api/v1/namespaces"
    "Marquez UI|3000|http|/healthcheck"
    "Prometheus|9095|http|/-/healthy"
    "Grafana|3001|http|/api/health"
    "MinIO API|9004|http|/minio/health/live"
    "MinIO Console|9005|http|/"
    "Trino|8091|http|/v1/info"
    "Superset|8090|http|/health"
  )
  local entry name port probe path endpoint state
  local healthy_count=0
  local degraded_count=0
  local stopped_count=0
  local exit_code=0

  echo "=== Service Health Report ==="
  printf '  %-18s %-9s %-6s %s\n' "Service" "State" "Probe" "Endpoint"
  for entry in "${services[@]}"; do
    IFS='|' read -r name port probe path <<< "${entry}"
    endpoint="$(status_probe_endpoint "${port}" "${probe}" "${path}")"

    if port_is_open localhost "${port}"; then
      if [[ "${probe}" == "http" ]] && ! http_probe_ok "${port}" "${path}"; then
        state="degraded"
        degraded_count=$((degraded_count + 1))
        exit_code=1
      else
        state="healthy"
        healthy_count=$((healthy_count + 1))
      fi
    else
      state="stopped"
      stopped_count=$((stopped_count + 1))
      exit_code=1
    fi

    printf '  %-18s %-9s %-6s %s\n' "${name}" "${state}" "${probe}" "${endpoint}"
  done

  echo
  echo "Healthy: ${healthy_count}  Degraded: ${degraded_count}  Stopped: ${stopped_count}"
  return "${exit_code}"
}

