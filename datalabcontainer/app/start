handle_cli_flag() {
  case "$1" in
    --help|-h|help)
      print_usage
      exit 0
      ;;
    --prune-logs)
      logs::prune_if_needed
      exit 0
      ;;

    # New stack-level flags
    --start-etl-stack|--quick-start-etl)
      start_etl_stack
      show_ui_services
      exit 0
      ;;
    --start-database-stack|--quick-start-databases)
      start_database_stack
      show_db_access_summary
      show_ui_services
      exit 0
      ;;
    --start-lakehouse-stack|--quick-start-lakehouse)
      start_lakehouse_stack
      show_ui_services
      exit 0
      ;;
    --start-quality-stack|--quick-start-quality)
      start_quality_stack
      show_quality_access_summary
      show_ui_services
      exit 0
      ;;
    --start-observability-stack|--quick-start-observability)
      start_observability_stack
      show_observability_access_summary
      show_ui_services
      exit 0
      ;;
    --start-full-platform|--quick-start-full-platform)
      start_full_platform
      show_db_access_summary
      show_quality_access_summary
      show_observability_access_summary
      show_ui_services
      exit 0
      ;;
    --setup-postgres-cdc)
      cdc::setup_postgres_demo
      show_ui_services
      exit 0
      ;;
    --verify-postgres-cdc)
      cdc::verify_postgres_demo
      show_ui_services
      exit 0
      ;;
    --reset-postgres-cdc)
      cdc::reset_postgres_demo
      show_ui_services
      exit 0
      ;;
    --run-great-expectations-demo)
      gx::run_demo_validation
      show_quality_access_summary
      show_ui_services
      exit 0
      ;;
    --run-lineage-demo)
      lineage::run_spark_demo
      show_observability_access_summary
      show_ui_services
      exit 0
      ;;
    --test-lakehouse-catalogs)
      hadoop::ensure_running
      hive::start_metastore
      trino::start
      trino::lakehouse_tests
      show_ui_services
      exit 0
      ;;
    --setup-lakehouse-demo)
      hadoop::ensure_running
      hive::start_metastore
      trino::start
      trino::setup_simple_demo
      show_ui_services
      exit 0
      ;;
    --status-services)
      show_running_services
      exit 0
      ;;
    --status-urls)
      show_status_urls
      exit 0
      ;;
    --status-connections)
      show_connection_details
      exit 0
      ;;

    # Legacy flags kept for compatibility
    --start-databases)
      start_database_stack
      show_db_access_summary
      show_ui_services
      exit 0
      ;;
    --start-lakehouse)
      start_lakehouse_stack
      show_ui_services
      exit 0
      ;;
    --start-core)
      hadoop::ensure_running
      spark::ensure_running
      hive::prepare_cli
      kafka::start
      schema_registry::start
      kafka_connect::start
      echo "[+] Spark, Hadoop, Hive, Kafka, Schema Registry, and Kafka Connect services started."
      show_ui_services
      exit 0
      ;;
    --validate-stack)
      run_stack_validation_dag
      show_ui_services
      exit 0
      ;;
    --test-lakehouse)
      hadoop::ensure_running
      hive::start_metastore
      trino::start
      trino::lakehouse_tests
      show_ui_services
      exit 0
      ;;
    --start-db-uis)
      start_db_uis_if_needed
      show_db_access_summary
      show_ui_services
      exit 0
      ;;
    --start-pgadmin)
      pgadmin::start
      show_db_access_summary
      show_ui_services
      exit 0
      ;;

    # Individual starts (unchanged)
    --start-spark) spark::ensure_running; show_ui_services; exit 0 ;;
    --start-hadoop) hadoop::start; show_ui_services; exit 0 ;;
    --start-hive) hive::prepare_cli; show_ui_services; exit 0 ;;
    --start-kafka) kafka::start; show_ui_services; exit 0 ;;
    --start-schema-registry) schema_registry::start; show_ui_services; exit 0 ;;
    --start-kafka-connect) kafka_connect::start; show_ui_services; exit 0 ;;
    --start-airflow) airflow::start; show_ui_services; exit 0 ;;
    --start-postgres) start_postgres_with_ui; show_db_access_summary; show_ui_services; exit 0 ;;
    --start-mongodb) start_mongodb_with_ui; show_db_access_summary; show_ui_services; exit 0 ;;
    --start-redis) start_redis_with_ui; show_db_access_summary; show_ui_services; exit 0 ;;
    --start-minio) minio::start; show_ui_services; exit 0 ;;
    --start-jupyter) jupyter::start; show_quality_access_summary; show_ui_services; exit 0 ;;
    --start-great-expectations) gx::start; show_quality_access_summary; show_ui_services; exit 0 ;;
    --start-lineage) lineage::start; show_observability_access_summary; show_ui_services; exit 0 ;;
    --start-prometheus) monitoring::start_prometheus; show_observability_access_summary; show_ui_services; exit 0 ;;
    --start-grafana) monitoring::start_grafana; show_observability_access_summary; show_ui_services; exit 0 ;;
    --start-trino) hadoop::ensure_running; hive::start_metastore; trino::start; show_ui_services; exit 0 ;;
    --start-superset) superset::start; show_ui_services; exit 0 ;;

    # Stop/restart passthrough from datalab_app
    --stop-*)
      exec bash /home/datalab/app/stop "$1"
      ;;
    --restart-*)
      exec bash /home/datalab/app/restart "$1"
      ;;
  esac
}

CLI_FLAG="$(cli::normalize_flag "${1:-}")"

