handle_cli_flag() {
  case "$1" in
    --help|-h|help)
      print_usage
      exit 0
      ;;
    --prune-logs)
      logs::prune_if_needed
      exit 0
      ;;

    # New stack-level flags
    --start-etl-stack|--quick-start-etl)
      start_etl_stack
      show_ui_services
      exit 0
      ;;
    --start-database-stack|--quick-start-databases)
      start_database_stack
      show_db_access_summary
      show_ui_services
      exit 0
      ;;
    --start-lakehouse-stack|--quick-start-lakehouse)
      start_lakehouse_stack
      show_ui_services
      exit 0
      ;;
    --start-full-platform|--quick-start-full-platform)
      start_full_platform
      show_db_access_summary
      show_ui_services
      exit 0
      ;;
    --test-lakehouse-catalogs)
      hadoop::ensure_running
      hive::start_metastore
      trino::start
      trino::lakehouse_tests
      show_ui_services
      exit 0
      ;;
    --setup-lakehouse-demo)
      hadoop::ensure_running
      hive::start_metastore
      trino::start
      trino::setup_simple_demo
      show_ui_services
      exit 0
      ;;
    --status-services)
      show_running_services
      exit 0
      ;;
    --status-urls)
      show_status_urls
      exit 0
      ;;
    --status-connections)
      show_connection_details
      exit 0
      ;;

    # Legacy flags kept for compatibility
    --start-databases)
      start_database_stack
      show_db_access_summary
      show_ui_services
      exit 0
      ;;
    --start-lakehouse)
      start_lakehouse_stack
      show_ui_services
      exit 0
      ;;
    --start-core)
      hadoop::ensure_running
      spark::start
      hive::prepare_cli
      kafka::start
      echo "[+] Spark, Hadoop, Hive, and Kafka services started."
      show_ui_services
      exit 0
      ;;
    --validate-stack)
      run_stack_validation_dag
      show_ui_services
      exit 0
      ;;
    --test-lakehouse)
      hadoop::ensure_running
      hive::start_metastore
      trino::start
      trino::lakehouse_tests
      show_ui_services
      exit 0
      ;;
    --start-db-uis)
      start_db_uis_if_needed
      show_db_access_summary
      show_ui_services
      exit 0
      ;;
    --start-pgadmin)
      pgadmin::start
      show_db_access_summary
      show_ui_services
      exit 0
      ;;

    # Individual starts (unchanged)
    --start-spark) spark::start; show_ui_services; exit 0 ;;
    --start-hadoop) hadoop::start; show_ui_services; exit 0 ;;
    --start-hive) hive::prepare_cli; show_ui_services; exit 0 ;;
    --start-kafka) kafka::start; show_ui_services; exit 0 ;;
    --start-airflow) airflow::start; show_ui_services; exit 0 ;;
    --start-postgres) start_postgres_with_ui; show_db_access_summary; show_ui_services; exit 0 ;;
    --start-mongodb) start_mongodb_with_ui; show_db_access_summary; show_ui_services; exit 0 ;;
    --start-redis) start_redis_with_ui; show_db_access_summary; show_ui_services; exit 0 ;;
    --start-minio) minio::start; show_ui_services; exit 0 ;;
    --start-trino) hadoop::ensure_running; hive::start_metastore; trino::start; show_ui_services; exit 0 ;;
    --start-superset) superset::start; show_ui_services; exit 0 ;;

    # Stop/restart passthrough from datalab_app
    --stop-*)
      exec bash /home/datalab/app/stop "$1"
      ;;
    --restart-*)
      exec bash /home/datalab/app/restart "$1"
      ;;
  esac
}

CLI_FLAG="$(cli::normalize_flag "${1:-}")"

if [[ "${CLI_FLAG}" == "--prune-logs" ]]; then
  handle_cli_flag "${CLI_FLAG}"
fi

logs::prune_if_needed
handle_cli_flag "${CLI_FLAG}" || true

echo
echo "=== Data Lab ==="
echo "1) Quick Start"
echo "2) Databases"
echo "3) Lakehouse & Analytics"
echo "4) Status & Access Info"
echo "5) Manage Services"
echo "0) Exit"
read -r -p "Select option: " opt
case "${opt}" in
  1) run_quick_start_menu ;;
  2) run_databases_menu ;;
  3) run_lakehouse_menu ;;
  4) run_status_menu ;;
  5) run_manage_services_menu ;;
  0) echo "Bye."; exit 0 ;;
  *) echo "Invalid option." ;;
esac
