#!/usr/bin/env bash
set -e

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_REPO_ROOT="$(cd "${APP_DIR}/.." && pwd)"
SERVICE_NAME="${SERVICE_NAME:-data-lab}"
CONTAINER_NAME="${CONTAINER_NAME:-datalab}"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
source "${APP_DIR}/tech/host_exec.sh"

datalab::ensure_inside_or_exec "${APP_REPO_ROOT}" "${SERVICE_NAME}" "${CONTAINER_NAME}" "/home/datalab/app/${SCRIPT_NAME}" "$@"

source "${APP_DIR}/tech/common.sh"
source "${APP_DIR}/tech/logs/manage.sh"
source "${APP_DIR}/tech/hadoop/manage.sh"
source "${APP_DIR}/tech/hive/manage.sh"
source "${APP_DIR}/tech/airflow/manage.sh"
source "${APP_DIR}/tech/kafka/manage.sh"
source "${APP_DIR}/tech/postgres/manage.sh"
source "${APP_DIR}/tech/mongodb/manage.sh"
source "${APP_DIR}/tech/redis/manage.sh"
source "${APP_DIR}/tech/dbui/manage.sh"
source "${APP_DIR}/tech/pgadmin/manage.sh"
source "${APP_DIR}/tech/spark/manage.sh"
source "${APP_DIR}/tech/minio/manage.sh"
source "${APP_DIR}/tech/trino/manage.sh"
source "${APP_DIR}/tech/superset/manage.sh"
source "${APP_DIR}/tech/service_groups.sh"
source "${APP_DIR}/tech/cli_flags.sh"

show_ui_services() {
  local ui_cmd="/home/datalab/app/ui_services"
  if [[ -x "${ui_cmd}" ]]; then
    echo
    echo "=== UI Links ==="
    bash "${ui_cmd}" --list || true
  fi
}

show_db_access_summary() {
  local server_label="${CONTAINER_NAME:-datalab}"
  local pg_host pg_port mongo_host mongo_port redis_host redis_port
  local pgadmin_url mongo_ui_url redis_ui_url
  local pg_db pg_user pg_password mongo_db mongo_user mongo_password redis_password

  pg_host="${DATALAB_UI_HOST:-localhost}"
  mongo_host="${DATALAB_UI_HOST:-localhost}"
  redis_host="${DATALAB_UI_HOST:-localhost}"
  pg_port="$(common::mapped_host_port "${POSTGRES_PORT:-5432}")"
  mongo_port="$(common::mapped_host_port "${MONGO_PORT:-27017}")"
  redis_port="$(common::mapped_host_port "${REDIS_PORT:-6379}")"
  pgadmin_url="$(common::ui_url "${PGADMIN_PORT:-8181}" "/")"
  mongo_ui_url="$(common::ui_url "${MONGO_EXPRESS_PORT:-8083}" "/")"
  redis_ui_url="$(common::ui_url "${REDIS_COMMANDER_PORT:-8084}" "/")"

  pg_db="${POSTGRES_DB:-datalab}"
  pg_user="${POSTGRES_USER:-admin}"
  pg_password="${POSTGRES_PASSWORD:-admin}"
  mongo_db="${MONGO_DB:-datalab}"
  mongo_user="${MONGO_ROOT_USERNAME:-admin}"
  mongo_password="${MONGO_ROOT_PASSWORD:-admin}"
  redis_password="${REDIS_PASSWORD:-admin}"

  echo
  echo "=== DB Access Summary ==="
  echo "Server Name (all tools): ${server_label}"
  echo "PostgreSQL: host=${pg_host} port=${pg_port} db=${pg_db} username=${pg_user} password=${pg_password}"
  echo "MongoDB:    host=${mongo_host} port=${mongo_port} db=${mongo_db} username=${mongo_user} password=${mongo_password} authDb=admin"
  echo "Redis:      host=${redis_host} port=${redis_port} username=default password=${redis_password}"
  echo "MongoDB UI: ${mongo_ui_url}"
  echo "Redis UI:   ${redis_ui_url}"
  echo "pgAdmin UI: ${pgadmin_url} (login: ${PGADMIN_EMAIL:-admin@admin.com} / ${PGADMIN_PASSWORD:-admin})"
}

start_db_uis_if_needed() {
  dbui::start
  pgadmin::start
}

start_postgres_with_ui() {
  postgres::start
  pgadmin::start
}

start_mongodb_with_ui() {
  mongodb::start
  dbui::start_mongo_express
}

start_redis_with_ui() {
  redis::start
  dbui::start_redis_commander
}

start_etl_stack() {
  groups::start_etl
  echo "[+] ETL stack started (Airflow/Spark/Hadoop/Hive/Kafka)."
}

start_database_stack() {
  groups::start_databases
  echo "[+] Database stack started (PostgreSQL/MongoDB/Redis + Mongo Express/Redis Commander/pgAdmin)."
}

start_lakehouse_stack() {
  groups::start_lakehouse
  echo "[+] Lakehouse stack started (MinIO/Trino/Superset + Hive/Hadoop)."
}

start_full_platform() {
  groups::start_full_platform
  echo "[+] Full platform started (ETL + Databases + Lakehouse)."
}

run_stack_validation_dag() {
  local dag_id="data_lab_stack_validation"
  local exec_date
  airflow::start
  exec_date="$(date +%F)"
  echo "[*] Running Airflow DAG '${dag_id}' for date ${exec_date}..."
  if airflow dags test "${dag_id}" "${exec_date}"; then
    echo "[+] Airflow DAG '${dag_id}' completed successfully."
  else
    echo "[!] Airflow DAG '${dag_id}' failed. Check Airflow task logs for details." >&2
    return 1
  fi
}

port_is_open() {
  local host="$1" port="$2"
  STATUS_WAIT_HOST="${host}" STATUS_WAIT_PORT="${port}" python3 - <<'PY'
import os, socket, sys
host = os.environ["STATUS_WAIT_HOST"]
port = int(os.environ["STATUS_WAIT_PORT"])
s = socket.socket()
s.settimeout(1)
try:
    s.connect((host, port))
except OSError:
    sys.exit(1)
else:
    s.close()
    sys.exit(0)
PY
}

show_running_services() {
  local services=(
    "Airflow:8080"
    "Spark Master:9090"
    "Hadoop NameNode:9870"
    "HiveServer2 HTTP:10001"
    "Kafka UI:9002"
    "PostgreSQL:5432"
    "MongoDB:27017"
    "Redis:6379"
    "Mongo Express:8083"
    "Redis Commander:8084"
    "MinIO:${MINIO_API_PORT}"
    "Trino:8091"
    "Superset:8090"
  )
  local entry name port status

  echo "=== Running Services ==="
  for entry in "${services[@]}"; do
    name="${entry%%:*}"
    port="${entry##*:}"
    if [[ "${name}" == "MinIO" ]]; then
      if minio::is_running; then
        status="running"
      else
        status="stopped"
      fi
    elif port_is_open localhost "${port}"; then
      status="running"
    else
      status="stopped"
    fi
    printf '  %-18s %s\n' "${name}:" "${status}"
  done
}

show_status_urls() {
  echo "=== Service URLs ==="
  bash /home/datalab/app/ui_services --list || true
}

show_connection_details() {
  echo "=== Connection Details ==="
  bash /home/datalab/app/ui_services --all || true
}

print_usage() {
  cat <<'EOF'
Data Lab CLI

Start flags:
  --start-etl-stack           Start Airflow + Spark + Hadoop + Hive + Kafka
  --start-database-stack      Start PostgreSQL + MongoDB + Redis (+ Mongo Express/Redis Commander/pgAdmin)
  --start-lakehouse-stack     Start MinIO + Trino + Superset + Hive/Hadoop
  --start-full-platform       Start ETL + Databases + Lakehouse
  --test-lakehouse-catalogs   Run Trino lakehouse smoke tests
  --setup-lakehouse-demo      Create simple demo schemas/tables (hudi/delta/iceberg)
  --status-services           Show running/stopped service status
  --status-urls               Show UI URLs
  --status-connections        Show full connection details

Manage individual starts:
  --start-airflow --start-spark --start-hadoop --start-hive --start-kafka
  --start-minio --start-trino --start-superset
  --start-postgres --start-mongodb --start-redis

Stop/Restart:
  Use stop/restart flags directly from datalab_app, for example:
  --stop-lakehouse-stack
  --restart-database-stack

Legacy flags are still supported for compatibility.
EOF
}

run_quick_start_menu() {
  local opt
  echo
  echo "=== Quick Start ==="
  echo "1) Start ETL Stack"
  echo "2) Start Database Stack"
  echo "3) Start Lakehouse Stack"
  echo "4) Start Full Platform"
  echo "0) Back"
  read -r -p "Select option: " opt
  case "${opt}" in
    1) start_etl_stack; show_ui_services ;;
    2) start_database_stack; show_db_access_summary; show_ui_services ;;
    3) start_lakehouse_stack; show_ui_services ;;
    4) start_full_platform; show_db_access_summary; show_ui_services ;;
    0) return 0 ;;
    *) echo "Invalid option." ;;
  esac
  return 0
}

