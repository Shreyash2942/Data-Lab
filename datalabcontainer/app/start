run_stack_validation_dag() {
  local dag_id="data_lab_stack_validation"
  local exec_date
  airflow::start
  exec_date="$(date +%F)"
  echo "[*] Running Airflow DAG '${dag_id}' for date ${exec_date}..."
  if airflow dags test "${dag_id}" "${exec_date}"; then
    if ! VALIDATION_DAG_ID="${dag_id}" python3 - <<'PY'
from airflow.models import DagRun, TaskInstance
from airflow.utils.session import create_session

dag_id = __import__("os").environ["VALIDATION_DAG_ID"]
with create_session() as session:
    dag_run = (
        session.query(DagRun)
        .filter(DagRun.dag_id == dag_id)
        .order_by(DagRun.execution_date.desc())
        .first()
    )
    if dag_run is None:
        raise SystemExit(f"No DagRun found for {dag_id}")

    task_instances = (
        session.query(TaskInstance)
        .filter(TaskInstance.dag_id == dag_id, TaskInstance.run_id == dag_run.run_id)
        .all()
    )
    failures = [
        ti for ti in task_instances
        if ti.state != "success" and ti.task_id != "cleanup_validation_artifacts"
    ]
    if failures:
        details = ", ".join(f"{ti.task_id}={ti.state}" for ti in failures)
        raise SystemExit(f"Validation DAG had failed or skipped tasks: {details}")
PY
    then
      echo "[!] Airflow DAG '${dag_id}' finished with failed or skipped tasks." >&2
      return 1
    fi
    echo "[+] Airflow DAG '${dag_id}' completed successfully."
  else
    echo "[!] Airflow DAG '${dag_id}' failed. Check Airflow task logs for details." >&2
    return 1
  fi
}

port_is_open() {
  local host="$1" port="$2"
  STATUS_WAIT_HOST="${host}" STATUS_WAIT_PORT="${port}" python3 - <<'PY'
import os, socket, sys
host = os.environ["STATUS_WAIT_HOST"]
port = int(os.environ["STATUS_WAIT_PORT"])
s = socket.socket()
s.settimeout(1)
try:
    s.connect((host, port))
except OSError:
    sys.exit(1)
else:
    s.close()
    sys.exit(0)
PY
}

show_running_services() {
  local services=(
    "Airflow:8080"
    "Spark Master:9090"
    "Hadoop NameNode:9870"
    "HiveServer2:10000"
    "Kafka UI:9002"
    "Schema Registry:8085"
    "Kafka Connect:8086"
    "PostgreSQL:5432"
    "MongoDB:27017"
    "Redis:6379"
    "Mongo Express:8083"
    "Redis Commander:8084"
    "JupyterLab:8888"
    "GX Data Docs:8891"
    "Marquez API:5000"
    "Marquez UI:3000"
    "Prometheus:9095"
    "Grafana:3001"
    "MinIO:${MINIO_API_PORT}"
    "Trino:8091"
    "Superset:8090"
  )
  local entry name port status

  echo "=== Running Services ==="
  for entry in "${services[@]}"; do
    name="${entry%%:*}"
    port="${entry##*:}"
    if [[ "${name}" == "MinIO" ]]; then
      if minio::is_running; then
        status="running"
      else
        status="stopped"
      fi
    elif port_is_open localhost "${port}"; then
      status="running"
    else
      status="stopped"
    fi
    printf '  %-18s %s\n' "${name}:" "${status}"
  done
}

